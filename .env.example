# Shared environment variables (root level)
CONVEX_URL=

# Email configuration (for Resend email sending)
# Your verified Resend domain for sending emails (e.g., notes.yourdomain.com)
EMAIL_DOMAIN=

# ngrok tunnel domains (for local dev with external access)
# Replace with your own ngrok domains
NGROK_AUTHTOKEN=
NGROK_API_DOMAIN=your-api.ngrok.dev
NGROK_WEB_DOMAIN=your-web.ngrok.dev
NGROK_APP_DOMAIN=your-app.ngrok-free.app

# API app environment variables (apps/api)
API_PORT=3001
MENTRAOS_API_KEY=
AUTH_PUBLIC_KEY_PEM=
AUTH_PRIVATE_KEY_PEM=
AUTH_KEY_ID=
PUBLIC_BASE_URL=
RAILWAY_PUBLIC_DOMAIN=

# Application app environment variables (apps/application)
PACKAGE_NAME=com.mentra.clairvoyant
PORT=8080
GROQ_API_KEY=
OPENAI_API_KEY=
OPENWEATHERMAP_API_KEY=
TAVILY_API_KEY=
GOOGLE_MAPS_API_KEY=
HONCHO_API_KEY=

# Web app environment variables (apps/web)
VITE_CONVEX_URL=
VITE_API_BASE_URL=
