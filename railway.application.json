{
	"$schema": "https://railway.com/railway.schema.json",
	"build": {
		"builder": "RAILPACK",
		"buildCommand": "bun install",
		"watchPatterns": ["apps/application/**", "packages/convex/**", "baml_src/**", "package.json", "bun.lock"]
	},
	"deploy": {
		"startCommand": "bun run --cwd apps/application start",
		"restartPolicyType": "ON_FAILURE",
		"restartPolicyMaxRetries": 10
	}
}
