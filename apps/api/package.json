{
	"name": "@clairvoyant/api",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"main": "src/index.ts",
	"types": "src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"scripts": {
		"dev": "bun run --env-file=../../.env.local --env-file=.env.local --watch src/index.ts",
		"start": "bun run --env-file=../../.env.local --env-file=.env.local src/index.ts",
		"lint": "bunx biome check .",
		"typecheck": "tsc --noEmit",
		"test": "echo 'No tests configured for @clairvoyant/api'"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.1",
		"@t3-oss/env-core": "^0.13.10",
		"convex": "^1.31.7",
		"jose": "^6.1.3",
		"jsonwebtoken": "^9.0.3",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/jsonwebtoken": "^9.0.10",
		"typescript": "^5.9.3"
	}
}
